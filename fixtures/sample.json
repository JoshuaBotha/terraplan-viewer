        "actions": ["create"],
        "before": null,
        "after": {
          "cidr_block": "10.0.2.0/24",
          "availability_zone": "us-east-1b",
          "map_public_ip_on_launch": true
        },
        "after_unknown": {
          "id": true,
          "vpc_id": true
        }
      }
    },
    {
      "address": "module.app.aws_lb.main",
      "module_address": "module.app",
