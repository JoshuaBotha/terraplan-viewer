      "provider_name": "registry.terraform.io/hashicorp/aws",
      "change": {
        "actions": ["delete", "create"],
        "before": {
          "engine": "postgres",
          "engine_version": "13.7",
          "instance_class": "db.t3.small",
          "allocated_storage": 20,
          "username": "admin"
        },
        "after": {
          "engine": "postgres",
          "engine_version": "15.4",
          "instance_class": "db.t3.medium",
          "allocated_storage": 50,
          "username": "admin"
        },
        "after_unknown": {
          "id": true,
          "endpoint": true,
          "address": true
        },
        "replace_paths": [["engine_version"]]
      }
    },
    {
      "address": "aws_route53_record.api",
      "module_address": "",
      "mode": "managed",
      "type": "aws_route53_record",
      "name": "api",
      "provider_name": "registry.terraform.io/hashicorp/aws",
      "change": {
        "actions": ["no-op"],
        "before": {
          "name": "api.example.com",
          "type": "A",
          "ttl": 300
        },
        "after": {
          "name": "api.example.com",
          "type": "A",
          "ttl": 300
        },
        "after_unknown": {}
      }
    },
    {
      "address": "data.aws_ami.ubuntu",
      "module_address": "",
      "mode": "data",
      "type": "aws_ami",
      "name": "ubuntu",
      "provider_name": "registry.terraform.io/hashicorp/aws",
