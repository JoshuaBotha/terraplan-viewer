      "change": {
        "actions": ["create"],
        "before": null,
        "after": {
          "cidr_block": "10.0.1.0/24",
          "availability_zone": "us-east-1a",
          "map_public_ip_on_launch": true
        },
        "after_unknown": {
          "id": true,
          "vpc_id": true
        }
      }
    },
    {
      "address": "module.network.aws_subnet.public[1]",
      "module_address": "module.network",
      "mode": "managed",
      "type": "aws_subnet",
      "name": "public",
