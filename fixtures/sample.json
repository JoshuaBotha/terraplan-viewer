        "actions": ["read"],
        "before": null,
        "after": {
          "most_recent": true,
          "owners": ["099720109477"]
        },
        "after_unknown": {
          "id": true,
          "image_id": true
        }
      }
    },
    {
      "address": "module.network.aws_vpc.main",
      "module_address": "module.network",
      "mode": "managed",
      "type": "aws_vpc",
