{
  "format_version": "1.2",
  "terraform_version": "1.6.0",
  "resource_changes": [
    {
      "address": "aws_instance.web",
      "module_address": "",
      "mode": "managed",
      "type": "aws_instance",
      "name": "web",
      "provider_name": "registry.terraform.io/hashicorp/aws",
      "change": {
        "actions": ["create"],
        "before": null,
        "after": {
          "ami": "ami-0abcd1234",
          "instance_type": "t3.micro",
          "tags": { "Name": "web", "Env": "dev" },
          "associate_public_ip_address": true
        },
        "after_unknown": {
          "id": true,
          "arn": true,
          "private_ip": true
        },
        "before_sensitive": false,
        "after_sensitive": false
      }
    },
    {
      "address": "aws_security_group.web",
      "module_address": "",
      "mode": "managed",
      "type": "aws_security_group",
      "name": "web",
      "provider_name": "registry.terraform.io/hashicorp/aws",
      "change": {
        "actions": ["update"],
        "before": {
          "name": "web-sg",
          "description": "web traffic",
          "ingress": [
            { "from_port": 80, "to_port": 80, "protocol": "tcp", "cidr_blocks": ["0.0.0.0/0"] }
          ],
          "tags": { "Env": "dev" }
        },
        "after": {
          "name": "web-sg",
          "description": "web and tls traffic",
          "ingress": [
            { "from_port": 80,  "to_port": 80,  "protocol": "tcp", "cidr_blocks": ["0.0.0.0/0"] },
            { "from_port": 443, "to_port": 443, "protocol": "tcp", "cidr_blocks": ["0.0.0.0/0"] }
          ],
          "tags": { "Env": "dev", "Owner": "platform" }
        },
        "after_unknown": {}
      }
    },
    {
      "address": "aws_s3_bucket.legacy",
      "module_address": "",
      "mode": "managed",
      "type": "aws_s3_bucket",
      "name": "legacy",
      "provider_name": "registry.terraform.io/hashicorp/aws",
      "change": {
        "actions": ["delete"],
        "before": {
          "bucket": "legacy-data-2019",
          "acl": "private",
          "versioning": [{ "enabled": true }]
        },
        "after": null,
        "after_unknown": {}
      }
    },
    {
      "address": "aws_db_instance.main",
      "module_address": "",
